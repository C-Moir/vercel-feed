# URLScan.io - free API key at https://urlscan.io/user/signup
# Without this, public scans are rate-limited to ~2/min
URLSCAN_KEY=

# Upstash Redis - enables consensus abuse reporting
# Free at https://upstash.com - create Redis DB, copy REST URL + token
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# AbuseIPDB - enables automatic C2 IP reporting
# Free API key at https://www.abuseipdb.com/api
ABUSEIPDB_KEY=

# Discord or Slack webhook URL
WEBHOOK_URL=

# GitHub personal access token - unlocks GitHub Pages detection via Events API
# Without: 60 req/hr (polls every 65s). With: 5000 req/hr (polls every 30s).
# No special scopes needed - public events only.
# Create at https://github.com/settings/tokens (classic, no scopes required)
GITHUB_TOKEN=

# Google Safe Browsing - optional second phishing layer
# Requires Google Cloud billing enabled even for free tier
GOOGLE_SB_KEY=
